# Local dev port
PORT=5000

# MongoDB Atlas/local connection string
MONGO_URI=your_mongodb_connection_string

# Allowed frontend origins (comma-separated supported)
FRONTEND_URL=http://localhost:5173

# Optional regex patterns for allowed origins (comma-separated)
# Example for Vercel previews:
# FRONTEND_URL_REGEX=^https://ledger-cfo-.*\\.vercel\\.app$
FRONTEND_URL_REGEX=

# API rate limit settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional backend public URL
BACKEND_URL=http://localhost:5000
